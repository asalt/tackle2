<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>AI Summaries — {{ savedir_name }}</title>
  <link rel="stylesheet" href="{{ static_href }}">
  <style type="text/css">
    html, body {
      width: 100% !important;
      max-width: 100% !important;
      margin: 0;
      padding: 0;
    }
    .main-container {
      max-width: 100% !important;
      margin: auto;
    }
    main.main-container {
      width: 100%;
      padding: 1.6rem 1rem 3rem 1rem;
      box-sizing: border-box;
    }
  </style>
</head>
<body>
  <main class="main-container">
  <header>
    <p class="meta"><a href="{{ back_href }}">← Back to Summary</a></p>
    <h1>AI Summaries</h1>
    <p class="subtitle">{{ savedir_name }}</p>
    <p class="meta">Generated {{ generated_at }} from <code>{{ savedir_path }}</code></p>
  </header>

  <section class="llm-summary">
    <h2>Use With Care</h2>
    <p>These AI-generated notes can make mistakes. Check important findings against the source tables, plots, and pathway results before relying on them.</p>
    <p class="meta">This summary flow is built with llama3.1 tulu via the shared agent API.</p>
  </section>

  {% if run_summary %}
  <section class="llm-summary">
    <h2>Run Overview</h2>
    <p>{{ run_summary.text }}</p>
    {% if run_summary.bullets %}
    <ul>
      {% for bullet in run_summary.bullets %}
      <li>{{ bullet }}</li>
      {% endfor %}
    </ul>
    {% endif %}
    {% if run_summary.model %}
    <p class="meta">Generated with {{ run_summary.model }}</p>
    {% endif %}
  </section>
  {% endif %}

  {% for collection in collection_sections %}
  <section class="collection">
    <header>
      <h2>
        {% if collection.href %}
        <a href="{{ collection.href }}">{{ collection.name }}</a>
        {% else %}
        {{ collection.name }}
        {% endif %}
      </h2>
    </header>

    {% if collection.summary %}
    <article class="llm-summary">
      <h3>Collection Summary</h3>
      <p>{{ collection.summary.text }}</p>
      {% if collection.summary.bullets %}
      <ul>
        {% for bullet in collection.summary.bullets %}
        <li>{{ bullet }}</li>
        {% endfor %}
      </ul>
      {% endif %}
    </article>
    {% endif %}

    {% for comparison in collection.comparisons %}
    <article class="comparison">
      <header>
        <h3>
          {% if comparison.href %}
          <a href="{{ comparison.href }}">{{ comparison.name }}</a>
          {% else %}
          {{ comparison.name }}
          {% endif %}
        </h3>
      </header>

      {% if comparison.summary %}
      <div class="llm-summary">
        <h4>Comparison Summary</h4>
        <p>{{ comparison.summary.text }}</p>
        {% if comparison.summary.bullets %}
        <ul>
          {% for bullet in comparison.summary.bullets %}
          <li>{{ bullet }}</li>
          {% endfor %}
        </ul>
        {% endif %}
      </div>
      {% endif %}

      {% if comparison.leading_edges %}
      <div class="llm-summary">
        <h4>Leading-Edge Notes</h4>
        {% for pathway in comparison.leading_edges %}
        <article class="comparison">
          <header>
            <h5>{{ pathway.name }}</h5>
            <p class="meta">
              NES {{ "%.2f"|format(pathway.nes) if pathway.nes is not none else "NA" }}
              · Padj {{ "%.3g"|format(pathway.padj) if pathway.padj is not none else "NA" }}
            </p>
          </header>
          <p>{{ pathway.summary.text }}</p>
          {% if pathway.summary.bullets %}
          <ul>
            {% for bullet in pathway.summary.bullets %}
            <li>{{ bullet }}</li>
            {% endfor %}
          </ul>
          {% endif %}
        </article>
        {% endfor %}
      </div>
      {% endif %}
    </article>
    {% endfor %}
  </section>
  {% endfor %}

  <footer>
    <p>Static AI summary report generated by tackle2.</p>
  </footer>
  </main>
</body>
</html>
